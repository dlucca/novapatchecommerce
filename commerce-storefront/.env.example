# ─── Medusa Backend ───────────────────────────────────────────────────────────
# URL del backend Medusa (Railway). En Vercel usar la URL de produccion de Railway.
MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable key del sales channel en Medusa Admin
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL publica del storefront. En Vercel: https://tu-proyecto.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Region por defecto si no se puede detectar. Opciones: mx | br
NEXT_PUBLIC_DEFAULT_REGION=mx

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Revalidacion ─────────────────────────────────────────────────────────────
# Secret para revalidar cache en Vercel (cualquier string aleatorio)
REVALIDATE_SECRET=

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Activar/desactivar secciones del storefront (true | false)
NEXT_PUBLIC_ENABLE_CART=true
NEXT_PUBLIC_ENABLE_STORE=true
NEXT_PUBLIC_ENABLE_COLLECTIONS=true
NEXT_PUBLIC_ENABLE_PRODUCTS=true
NEXT_PUBLIC_ENABLE_ORDERS=true
NEXT_PUBLIC_ENABLE_COUNTRY_SELECTOR=true
NEXT_PUBLIC_ENABLE_PRODUCT_CATALOG=true
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_SUBSCRIPTIONS=true

# Forzar una region fija (ignorar deteccion por URL). Solo para MVP/testing.
NEXT_PUBLIC_USE_FIXED_REGION=false
